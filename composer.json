{
	"name": "gcgov/framework-service-user-crud",
	"type": "framework-service",
	"description": "Implement standard CRUD routes to manage the user collection. Even if your app doesn't provide a custom user model (`\\app\\models\\user`), your auth or database service may provide you with a standard user model that implements (`\\gcgov\\framework\\interfaces\\auth\\user`).",
	"license": "MIT",
	"autoload": {
		"psr-4": {
			"gcgov\\framework\\services\\usercrud\\": "src/"
		}
	},
	"autoload-dev": {
		"psr-4": {
			"app\\models\\": "tests/Stubs/app/models/",
			"gcgov\\framework\\services\\usercrud\\tests\\": "tests/"
		},
		"files": [
			"tests/Stubs/FakeUserModel.php"
		]
	},
	"require": {
		"php": ">=8.1"
	},
	"require-dev": {
		"phpstan/phpstan": "^2.1",
		"phpunit/phpunit": "^10.5",
		"jetbrains/phpstorm-attributes": "^1.0",
		"gcgov/framework": "dev-main"
	},
	"repositories": [
		{ "type": "path", "url": "c:/inetpub/www/packages/framework", "options": { "symlink": false } }
	],
	"scripts": {
		"phpstan": "phpstan analyse --memory-limit=512M",
		"test": "phpunit",
		"ci": ["@phpstan", "@test"]
	}
}
